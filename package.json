{
  "name": "xiaolu-desktop-pet",
  "productName": "小鹿共学搭子",
  "version": "0.2.1",
  "author": "Xiaolu",
  "license": "MIT",
  "private": true,
  "description": "A focused, local-first desktop companion for Xiaolu.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "pnpm build && electron .",
    "start:built": "electron .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && node tests/game.test.mjs",
    "check": "pnpm typecheck && pnpm test",
    "package:msi": "pnpm build && electron-builder --win msi --x64"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.9.1",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "dev.xiaolu.study-mate",
    "productName": "小鹿共学搭子",
    "electronDist": "node_modules/electron/dist",
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "msiProjectCreated": "scripts/msi-project-created.cjs",
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/app-icon.ico",
      "artifactName": "xiaolu-study-mate-${version}-${arch}.${ext}"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "upgradeCode": "8B4F35F3-2A5E-4AB8-9C21-5D7A1E4F9062",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "additionalLightArgs": [
        "-loc",
        "zh-cn.wxl"
      ]
    }
  }
}
